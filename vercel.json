{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": [
          "Dolce Vita Bodrum.dc.html",
          "admin.html",
          "support.js",
          "image-slot.js",
          "omelette-bridge.js",
          "vendor/**",
          "assets/**",
          "uploads/**"
        ]
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/server.js"
    }
  ]
}
